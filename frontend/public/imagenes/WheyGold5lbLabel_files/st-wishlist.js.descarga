    }
    fetchCustom.prototype = {
      init() {
      },
      get(endpoint, options2 = {}) {
        try {
          const { headers } = options2;
          return fetch(baseURL + endpoint, {
            method: "get",
            headers: Object.assign(_headers, headers)
          }).then((res) => res.json()).then(checkError);
        } catch (error) {
          throw error;
        }
      },
      async post(endpoint, data, options2 = {}) {
        try {
