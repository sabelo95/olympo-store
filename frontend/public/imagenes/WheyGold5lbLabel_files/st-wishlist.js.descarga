  // src/scripts/helpers/debounce.js
  function debounce(fn, wait) {
    let t;
    return (...args) => {
      clearTimeout(t);
      return new Promise((resolve) => {
        t = setTimeout(() => {
          fn.apply(this, args);
          resolve(true);
        }, wait);
      });
    };
  }

