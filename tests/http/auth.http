### Olympo Store — Auth / login-service endpoints
### Todos los endpoints pasan por el api-gateway en el puerto 8081

@gateway = http://localhost:8081

###############################################################################
# 1. Login como ADMINISTRADOR
###############################################################################
# @name loginAdmin
POST {{gateway}}/auth/login
Content-Type: application/json

{
  "correo": "admin@olympostore.com",
  "contrasena": "Admin123!"
}

###############################################################################
# 2. Login como CLIENTE
###############################################################################
# @name loginCliente
POST {{gateway}}/auth/login
Content-Type: application/json

{
  "correo": "cliente@test.com",
  "contrasena": "Cliente123!"
}

###############################################################################
# Variables — pega aquí el token del login anterior
###############################################################################
@token = <PEGAR_ACCESS_TOKEN_AQUI>

###############################################################################
# 3. Crear usuario nuevo (registro)
###############################################################################
POST {{gateway}}/auth/crear
Content-Type: application/json

{
  "nombre": "Usuario Prueba",
  "correo": "prueba@test.com",
  "contrasena": "Prueba123!",
  "rol": "CLIENTE"
}

###############################################################################
# 4. Listar todos los usuarios (requiere token ADMIN)
###############################################################################
GET {{gateway}}/auth/usuarios
Authorization: Bearer {{token}}

###############################################################################
# 5. Obtener usuario por ID
###############################################################################
@usuarioId = 1

GET {{gateway}}/auth/obtener/{{usuarioId}}
Authorization: Bearer {{token}}

###############################################################################
# 6. Actualizar usuario
###############################################################################
PUT {{gateway}}/auth/actualizar/{{usuarioId}}
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "nombre": "Nombre Actualizado",
  "correo": "actualizado@test.com",
  "contrasena": "NuevaClave123!",
  "rol": "CLIENTE"
}

###############################################################################
# 7. Eliminar usuario
###############################################################################
@usuarioIdEliminar = 99

DELETE {{gateway}}/auth/eliminar/{{usuarioIdEliminar}}
Authorization: Bearer {{token}}

###############################################################################
# 8. Refresh token
###############################################################################
@refreshToken = <PEGAR_REFRESH_TOKEN_AQUI>

POST {{gateway}}/auth/refresh
Content-Type: application/json

{
  "refreshToken": "{{refreshToken}}"
}

###############################################################################
# 9. Logout
###############################################################################
POST {{gateway}}/auth/logout
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "refreshToken": "{{refreshToken}}"
}
